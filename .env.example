# Gemini 2.5 Flash se consume mediante OpenRouter.
OPENROUTER_API_KEY=tu_api_key_aqui

# Este proyecto usa OCI Object Storage como unico origen de archivos fuente.
STORAGE_BACKEND=oci

# Configuracion OCI no secreta. No copies claves privadas dentro del proyecto.
OCI_CONFIG_PROFILE=DEFAULT
OCI_BUCKET_NAME=nombre_bucket_ejemplo
OCI_NAMESPACE=namespace_ejemplo
OCI_RAG_PREFIX=prefijo_documentos_ejemplo
OCI_DATA_PREFIX=prefijo_datos_ejemplo
